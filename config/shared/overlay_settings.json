        {
          "key": "cpu_mode",
          "label": "CPU Mode",
          "description": "Powersave saves battery, Performance maximizes speed",
          "type": "cycle",
          "values": [0, 1, 2, 3],
          "labels": ["Powersave", "Ondemand", "Performance", "Auto"],
          "default": 1
