        {
          "key": "rewind_buffer",
          "label": "Rewind Buffer",
          "description": "Off saves RAM, Large gives more rewind time",
          "type": "cycle",
          "values": [0, 1, 2, 3],
          "labels": ["Off", "Small (5s)", "Medium (15s)", "Large (30s)"],
          "default": 0
        },
        {
          "key": "frame_skip",
          "label": "Frame Skip",
          "description": "Skip frames to reduce GPU load (may cause judder)",
          "type": "cycle",
          "values": [0, 1, 2, 3],
          "labels": ["Off", "1/2", "1/3", "1/4"],
          "default": 0
        }
      ]
    },
    {
      "name": "Core",
