+//---------------------------------------------------------------------------------------
+// emu_frontend plugin ops (custom features shared with GLideN64 via overlay/emu_frontend.c)
+
+static void rice_swap_buffers(void)
+{
+    CoreVideo_GL_SwapBuffers();
+}
+
+static EmuOvlRenderBackend* rice_get_render(void)
+{
+    return overlay_sdl_get_backend();
+}
+
+// Rice is single-threaded — no GL thread pool — so dispatch is a direct call.
+static void rice_exec_on_video_thread(void (*fn)(void*), void* ctx)
+{
+    fn(ctx);
+}
+
+// Rice does not expose a user-configurable aspect ratio setting (it computes
+// the output from the N64 VI registers + display dimensions). We cycle a local
+// override that resizes the GL viewport. For the MVP, this is a no-op and the
+// overlay config's AspectRatio item stays as-is. The aspect-cycle shortcut
+// still triggers this callback; adding actual cycling is a future improvement.
+static void rice_cycle_aspect(void)
+{
+    // no-op: Rice aspect comes from VI registers, not a cycle-able setting
+}
+
+static bool s_frontendInitialized = false;
+
+static void ensure_frontend_init(void)
+{
+    if (s_frontendInitialized) return;
+    s_frontendInitialized = true;
+
+    EmuFrontendCoreAPI api;
+    memset(&api, 0, sizeof(api));
+    api.core_cmd      = (emu_fe_core_cmd_fn)      CoreDoCommand;
+    api.add_cheat     = (emu_fe_add_cheat_fn)     CoreAddCheat;
+    api.cheat_enabled = (emu_fe_cheat_enabled_fn) CoreCheatEnabled;
+
+    EmuFrontendPluginOps ops;
+    memset(&ops, 0, sizeof(ops));
+    ops.swap_buffers         = rice_swap_buffers;
+    ops.cycle_aspect         = rice_cycle_aspect;
+    ops.get_render           = rice_get_render;
+    ops.exec_on_video_thread = rice_exec_on_video_thread;
+
+    emu_frontend_init(&api, &ops);
+}
+
