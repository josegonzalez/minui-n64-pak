diff --git a/projects/unix/Makefile b/projects/unix/Makefile
index da26ff1..9955caa 100755
--- a/projects/unix/Makefile
+++ b/projects/unix/Makefile
@@ -140,11 +140,12 @@ endif
 
 SRCDIR = ../../src
 OBJDIR = _obj$(POSTFIX)
+OVERLAY_DIR = ../../../../overlay
 
 # base CFLAGS, LDLIBS, and LDFLAGS
 OPTFLAGS ?= -O3 -flto
 WARNFLAGS ?= -Wall
-CFLAGS += $(OPTFLAGS) $(WARNFLAGS) -ffast-math -fno-strict-aliasing -fvisibility=hidden -I$(SRCDIR)
+CFLAGS += $(OPTFLAGS) $(WARNFLAGS) -ffast-math -fno-strict-aliasing -fvisibility=hidden -I$(SRCDIR) -I$(OVERLAY_DIR)
 CXXFLAGS += -fvisibility-inlines-hidden
 LDFLAGS += $(SHARED)
 
@@ -266,7 +267,7 @@ ifeq ($(origin SDL_CFLAGS) $(origin SDL_LDLIBS), undefined undefined)
   SDL_LDLIBS += $(shell $(SDL_CONFIG) --libs)
 endif
 CFLAGS += $(SDL_CFLAGS)
-LDLIBS += $(SDL_LDLIBS)
+LDLIBS += $(SDL_LDLIBS) -lSDL2_ttf -lSDL2_image
 
 # set mupen64plus core API header path
 ifneq ("$(APIDIR)","")
@@ -370,7 +371,12 @@ SOURCE = \
 	$(SRCDIR)/TextureFilters_hq4x.cpp \
 	$(SRCDIR)/TextureManager.cpp \
 	$(SRCDIR)/VectorMath.cpp \
-	$(SRCDIR)/Video.cpp
+	$(SRCDIR)/Video.cpp \
+	$(OVERLAY_DIR)/emu_overlay.c \
+	$(OVERLAY_DIR)/emu_overlay_cfg.c \
+	$(OVERLAY_DIR)/emu_overlay_sdl.c \
+	$(OVERLAY_DIR)/emu_frontend.c \
+	$(OVERLAY_DIR)/cjson/cJSON.c
 
 ifeq ($(OS),MINGW)
 SOURCE += \
@@ -383,8 +389,11 @@ SOURCE += \
 endif
 
 # generate a list of object files build, make a temporary directory for them
-OBJECTS := $(patsubst $(SRCDIR)/%.c, $(OBJDIR)/%.o, $(filter %.c, $(SOURCE)))
-OBJECTS += $(patsubst $(SRCDIR)/%.cpp, $(OBJDIR)/%.o, $(filter %.cpp, $(SOURCE)))
+RICE_SOURCES := $(filter $(SRCDIR)/%,$(SOURCE))
+OVERLAY_SOURCES := $(filter $(OVERLAY_DIR)/%,$(SOURCE))
+OBJECTS := $(patsubst $(SRCDIR)/%.c, $(OBJDIR)/%.o, $(filter %.c, $(RICE_SOURCES)))
+OBJECTS += $(patsubst $(SRCDIR)/%.cpp, $(OBJDIR)/%.o, $(filter %.cpp, $(RICE_SOURCES)))
+OBJECTS += $(patsubst $(OVERLAY_DIR)/%.c, $(OBJDIR)/overlay/%.o, $(filter %.c, $(OVERLAY_SOURCES)))
 OBJDIRS = $(dir $(OBJECTS))
 $(shell $(MKDIR) $(OBJDIRS))
 
@@ -449,6 +458,10 @@ $(OBJDIR)/%.o: $(SRCDIR)/%.c
 $(OBJDIR)/%.o: $(SRCDIR)/%.cpp
 	$(COMPILE.cc) -o $@ $<
 
+# overlay sources live outside the Rice source tree
+$(OBJDIR)/overlay/%.o: $(OVERLAY_DIR)/%.c
+	$(COMPILE.c) -o $@ $<
+
 $(TARGET): $(OBJECTS)
 	$(LINK.o) $^ $(LOADLIBES) $(LDLIBS) -o $@
 
