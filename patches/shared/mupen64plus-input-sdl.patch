 #define M64P_PLUGIN_PROTOTYPES 1
 #include "config.h"
@@ -614,6 +615,79 @@ EXPORT void CALL GetKeys( int Control, BUTTONS *Keys )
         controller[Control].buttons.Y_AXIS = iY;
     }
 
+    /* Per-game D-pad-as-joystick override and Brick-specific C-button remap.
+     *
+     * Driven by a per-game config file at $EMU_INPUT_MODE_FILE (managed by
+     * emu_frontend). The file contains either `input_mode=joystick` — which
+     * routes the physical d-pad through the N64 analog stick (the device has
+     * no physical analog stick) — or `input_mode=dpad`, which leaves the
+     * config-mapped d-pad→N64-d-pad behavior intact. We stat() the file on
+     * every call and re-parse only when its mtime changes.
+     *
+     * R2 (axis 5) + ABXY still maps to C-buttons by physical position:
+     *   A (right) → C-Right, B (bottom) → C-Down,
+     *   X (top) → C-Up, Y (left) → C-Left. */
+    {
+        static int dpad_as_joystick = 1; /* default when file is missing: joystick mode */
+        static time_t cached_mtime = 0;
+        static const char* cached_path = NULL;
+        if (cached_path == NULL) {
+            cached_path = getenv("EMU_INPUT_MODE_FILE");
+            if (cached_path == NULL) cached_path = "";
+        }
+        if (cached_path[0] != '\0') {
+            struct stat st;
+            if (stat(cached_path, &st) == 0 && st.st_mtime != cached_mtime) {
+                cached_mtime = st.st_mtime;
+                FILE* f = fopen(cached_path, "r");
+                if (f) {
+                    char line[128];
+                    while (fgets(line, sizeof(line), f)) {
+                        if (strncmp(line, "input_mode=", 11) == 0) {
+                            /* "joystick" = route physical d-pad → N64 analog */
+                            /* "dpad"     = physical d-pad → N64 d-pad (passthrough) */
+                            dpad_as_joystick = (strncmp(line + 11, "joystick", 8) == 0);
+                            break;
+                        }
+                    }
+                    fclose(f);
+                }
+            }
+        }
+
+        SDL_Joystick *joy = controller[Control].joystick;
+        if (joy && Control == 0) {
+            if (dpad_as_joystick) {
+                Uint8 hat = SDL_JoystickGetHat(joy, 0);
+                controller[Control].buttons.Value &= ~0x000F; /* clear D-pad bits */
+                if (hat & SDL_HAT_RIGHT) controller[Control].buttons.X_AXIS =  80;
+                if (hat & SDL_HAT_LEFT)  controller[Control].buttons.X_AXIS = -80;
+                if (hat & SDL_HAT_UP)    controller[Control].buttons.Y_AXIS =  80;
+                if (hat & SDL_HAT_DOWN)  controller[Control].buttons.Y_AXIS = -80;
+            }
+
+            /* R2 modifier (axis 5 > 0): remap ABXY to C-buttons by position */
+            if (SDL_JoystickGetAxis(joy, 5) > 0) {
+                if (SDL_JoystickGetButton(joy, 1)) { /* A (right) → C-Right */
+                    controller[Control].buttons.Value &= ~0x0080; /* clear A_BUTTON */
+                    controller[Control].buttons.Value |=  0x0100; /* set R_CBUTTON */
+                }
+                if (SDL_JoystickGetButton(joy, 0)) { /* B (bottom) → C-Down */
+                    controller[Control].buttons.Value &= ~0x0040; /* clear B_BUTTON */
+                    controller[Control].buttons.Value |=  0x0400; /* set D_CBUTTON */
+                }
+                if (SDL_JoystickGetButton(joy, 3)) { /* X (top) → C-Up */
+                    controller[Control].buttons.Value &= ~0x0200; /* clear C-Left from config */
+                    controller[Control].buttons.Value |=  0x0800; /* set U_CBUTTON */
+                }
+                if (SDL_JoystickGetButton(joy, 2)) { /* Y (left) → C-Left */
+                    controller[Control].buttons.Value &= ~0x0400; /* clear C-Down from config */
+                    controller[Control].buttons.Value |=  0x0200; /* set L_CBUTTON */
+                }
+            }
+        }
+    }
+
     // process mouse events
     mstate = SDL_GetMouseState( NULL, NULL );
     for( b = 0; b < 16; b++ )
